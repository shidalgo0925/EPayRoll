[Unit]
Description=EPayRoll API (FastAPI + UI)
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=adminnode
WorkingDirectory=/opt/EPayRoll
EnvironmentFile=/opt/EPayRoll/.env
Environment=PYTHONPATH=src
ExecStart=/opt/EPayRoll/.venv/bin/python -m uvicorn epayroll.api.main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
